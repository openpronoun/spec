---
/**
 * PLACEHOLDER — example content owned by the maintainer.
 * This proves vanilla JS / Web Components work without any framework integration.
 */
import { placeholder } from "@openpronoun/core";

const value = placeholder();
---

<div
  id="vanilla-example"
  style="padding: 1rem; border: 1px solid #444; border-radius: 8px"
>
  <p><strong>Vanilla JS</strong> — via <code>@openpronoun/core</code>:</p>
  <p>
    Result: <code id="vanilla-result">{value}</code>
  </p>
</div>

<script>
  // Client-side hydration proof: updates the result after load.
  const el = document.getElementById("vanilla-result");
  if (el) {
    el.textContent = el.textContent + " ✓";
  }
</script>
