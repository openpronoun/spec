---
import { parse, format } from "@openpronoun/core";

// Server-side: pre-render the default so Alpine shows it on load.
const defaultInput = "she/her, they/them";
const defaultParsed = parse(defaultInput)!;
const defaultShort = format(defaultParsed);
const defaultExpanded = format(defaultParsed, { form: "expanded" });
---

<div
  x-data={`{
    short: ${JSON.stringify(defaultShort)},
    expanded: ${JSON.stringify(defaultExpanded)},
    entries: ${defaultParsed.length}
  }`}
  style="padding: 1rem; border: 1px solid #e2e8f0; border-radius: 8px; font-family: system-ui, sans-serif"
>
  <p style="margin: 0 0 8px; font-weight: 600">
    Alpine.js — <code>@openpronoun/core</code> (SSR)
  </p>
  <dl style="font-size: 13px; margin: 0">
    <div style="display: flex; gap: 8px; margin-bottom: 4px">
      <dt style="color: #718096; min-width: 80px">Input</dt>
      <dd style="margin: 0"><code>{defaultInput}</code></dd>
    </div>
    <div style="display: flex; gap: 8px; margin-bottom: 4px">
      <dt style="color: #718096; min-width: 80px">Short</dt>
      <dd style="margin: 0"><strong x-text="short"></strong></dd>
    </div>
    <div style="display: flex; gap: 8px; margin-bottom: 4px">
      <dt style="color: #718096; min-width: 80px">Expanded</dt>
      <dd style="margin: 0"><strong x-text="expanded"></strong></dd>
    </div>
    <div style="display: flex; gap: 8px">
      <dt style="color: #718096; min-width: 80px">Entries</dt>
      <dd style="margin: 0" x-text="entries"></dd>
    </div>
  </dl>
  <p style="color: #a0aec0; font-size: 11px; margin: 10px 0 0">
    Alpine runs in the browser and can't import Node ESM directly — parsing
    happens at build time via Astro. For live re-parsing, proxy to an API
    route that calls <code>@openpronoun/core</code> server-side.
  </p>
</div>
