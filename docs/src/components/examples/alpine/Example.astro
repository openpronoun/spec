---
/**
 * PLACEHOLDER — example content owned by the maintainer.
 * This proves the Alpine.js integration builds and hydrates.
 *
 * Alpine components in Astro use an .astro wrapper that outputs
 * the Alpine-enhanced HTML. The x-data initializes Alpine state.
 */
import { placeholder } from "@openpronoun/core";

const value = placeholder();
---

<div
  x-data={`{ value: "${value}" }`}
  style="padding: 1rem; border: 1px solid #444; border-radius: 8px"
>
  <p><strong>Alpine.js</strong> — via <code>@openpronoun/core</code>:</p>
  <p>
    Result: <code x-text="value"></code>
  </p>
</div>
